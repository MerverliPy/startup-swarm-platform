{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "instructions": [
    "AGENTS.md"
  ],
  "watcher": {
    "ignore": [
      "node_modules/**",
      "apps/**/node_modules/**",
      "dist/**",
      ".git/**",
      ".next/**",
      "apps/**/.next/**",
      "coverage/**",
      ".venv/**",
      "__pycache__/**",
      "apps/**/__pycache__/**",
      "runs/**",
      "data/**",
      "*.zip"
    ]
  }
}
